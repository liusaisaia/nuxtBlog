    "lucide-vue-next": "^1.0.0",
    "nuxt": "^4.3.1",
    "pg": "^8.18.0",
    "rss": "^1.2.2",
    "tailwindcss": "^3.4.17",
    "tdesign-vue-next": "^1.16.0",
    "vue": "^3.5.28",
    "vue-router": "^5.0.2"
